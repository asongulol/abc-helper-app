# ---------------------------------------------------------------------------
# ABC Helper App — environment variable reference
# Copy to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Supabase (required)
# Get from: Supabase dashboard → Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ---------------------------------------------------------------------------
# Admin SSO (required — restricts Google OAuth to this domain)
# ---------------------------------------------------------------------------
ADMIN_SSO_ALLOWED_DOMAIN=abckidsny.com

# ---------------------------------------------------------------------------
# Gmail SMTP — transactional email for new-hire / onboarding flow
# (optional — app boots and hiring works without these; every send no-ops)
#
# GMAIL_USER            : The Gmail or Google Workspace address to send from.
# GMAIL_APP_PASSWORD    : A Google App Password (not your account password).
#                         Generate at: myaccount.google.com → Security → App passwords
#                         Requires 2-Step Verification to be enabled.
# HIRING_REVIEW_EMAIL_FROM : Optional "Name <addr>" override for the From header.
#                            Defaults to "ABC Kids NY <GMAIL_USER>".
# ---------------------------------------------------------------------------
GMAIL_USER=hiring@abckidsny.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
HIRING_REVIEW_EMAIL_FROM=ABC Kids NY <hiring@abckidsny.com>

# ---------------------------------------------------------------------------
# App URL — used for portal links embedded in hire emails
# Set to the public portal URL in production.
# ---------------------------------------------------------------------------
APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Wise API (optional — DRAFT staging only; funding endpoints are forbidden)
# Get from: Wise developer portal
# ---------------------------------------------------------------------------
WISE_API_TOKEN=
WISE_PROFILE_ID=

# ---------------------------------------------------------------------------
# Hubstaff (optional — time ingestion)
# ---------------------------------------------------------------------------
HUBSTAFF_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# Cron secret (optional — secures cron-invoked API routes)
# ---------------------------------------------------------------------------
CRON_SECRET=
