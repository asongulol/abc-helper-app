# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
out/

# Next.js / TypeScript generated
next-env.d.ts
*.tsbuildinfo
# Vitest writes ephemeral compiled-config artifacts next to vitest.config.ts
*.timestamp-*.mjs

# Env & secrets
.env
.env.local
.env.*.local
*.pem
*.key
# Plaintext live-secrets handoff (must never be committed)
docs/ABC-HELPER-APP-VAR

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/
.nyc_output/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/

# Keep workspace VS Code settings, ignore per-user state
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!.vscode/launch.json
!.vscode/tasks.json

# Database
*.sqlite
*.sqlite3

# Vercel
.vercel

# Editor/FUSE deleted-but-open artifacts
.fuse_hidden*
**/.fuse_hidden*

# Finder/IDE "copy" duplicates (e.g. "loading 2.tsx", "0013 2.sql") — never real source
* [0-9].tsx
* [0-9].ts
* [0-9].sql
